# NovaHunter dashboard — local development environment
# Copy to .env.local:  cp .env.example .env.local

# ---- Demo mode ----
# When true: frontend runs standalone with realistic fake data (no backend needed).
# When false: frontend requires the NovaHunter API backend to be reachable.
NEXT_PUBLIC_DEMO=true

# ---- Backend API ----
# Used only when NEXT_PUBLIC_DEMO=false.
# Public URL of the API (e.g. http://localhost:80/api or https://your-host/api).
NEXT_PUBLIC_API_BASE_URL=

# ---- Auth (Clerk) ----
# Used only when NEXT_PUBLIC_DEMO=false.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---- Branding ----
NEXT_PUBLIC_APP_NAME=NovaHunter
NEXT_PUBLIC_APP_TAGLINE=AI-driven offensive-security control plane
