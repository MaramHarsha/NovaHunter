# Copy to deploy/.env and tweak. Do NOT commit real secrets.
# The installer at scripts/setup.sh generates this file for you — editing it
# by hand is only needed when changing infrastructure defaults.

# --- Core infrastructure -----------------------------------------------------
# `development` skips the hard Clerk-auth requirement so the stack boots on a
# fresh VPS. Switch to `production` after you have configured Clerk + LLM keys
# from the admin UI.
STRIX_ENV=development
STRIX_LOG_LEVEL=INFO
STRIX_ALLOWED_ORIGINS=*
STRIX_TRUSTED_HOSTS=*

# --- Caddy reverse proxy -----------------------------------------------------
# Leave STRIX_DOMAIN empty for an IP-only deployment (HTTP on :80).
# To enable HTTPS later: set STRIX_DOMAIN to a real FQDN, set a real email in
# STRIX_TLS_EMAIL, and switch deploy/Caddyfile's `:80 { ... }` site block to
# `{$STRIX_DOMAIN} { ... }`.
STRIX_DOMAIN=
STRIX_TLS_EMAIL=internal

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=strix
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=strix

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=NovaHunter
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_DEMO=false

# --- Clerk (https://dashboard.clerk.com) -------------------------------------
# Create an application, then copy API Keys + JWT "Issuer" / JWKS URL from the
# Clerk dashboard. Use pk_test_/sk_test_ for development, pk_live_/sk_live_ for
# production. Leave all Clerk vars empty to run the API in development without
# JWT auth (see README → Environment setup).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
# CLERK_AUDIENCE=

# Clerk uses the browser Web Crypto API for some cookies. On plain HTTP (e.g.
# bare IP :80), crypto.subtle is unavailable → console noise like "digest
# undefined" / suffixed cookie failures. Use HTTPS on a real hostname for prod,
# or expect limitations on HTTP-only demos.

# Platform-admin elevation (comma-separated). After Clerk works, set your
# Clerk email and/or user id from Clerk → Users.
STRIX_ADMIN_EMAILS=
STRIX_ADMIN_USER_IDS=

# --- LLM provider (required to launch scans) -------------------------------
# The Strix CLI will refuse to start a run if STRIX_LLM is empty, and the
# dashboard's "Launch scan" button will return a 400 telling you to set it.
# Any litellm-compatible model string works. Examples:
#   STRIX_LLM=openai/gpt-5.4
#   STRIX_LLM=anthropic/claude-4.5-sonnet
#   STRIX_LLM=openrouter/anthropic/claude-4.5-sonnet
# STRIX_LLM=openai/gpt-5.4
# LLM_API_KEY=sk-...                 # provider API key matching STRIX_LLM
# LLM_API_BASE=                      # only needed for custom OpenAI-compatible endpoints
# STRIX_REASONING_EFFORT=high        # low | medium | high
# PERPLEXITY_API_KEY=                # optional: enables the research tool

# --- Encrypted secret store -------------------------------------------------
# AES-256-GCM master key (64 hex chars). The router-admin UI and the secrets
# manager use this to encrypt API keys at rest in Postgres. Auto-generated by
# scripts/setup.sh when the .env file is first rendered. Rotating this value
# requires re-adding every secret via /admin/llm.
# STRIX_MASTER_KEY=

# --- Per-role LLM overrides (optional) --------------------------------------
# Only needed when you want to skip the admin UI and bake role routing into
# deploy/.env itself. Each role falls back to STRIX_LLM when its own var is
# unset. These take priority over STRIX_LLM but are overridden by DB routes
# (admin UI > .env > code defaults).
# STRIX_LLM_PLANNER=openai/gpt-4.1
# STRIX_LLM_EXECUTOR=openai/gpt-4.1-mini
# STRIX_LLM_REASONER=anthropic/claude-3-5-sonnet-latest
# STRIX_LLM_REPORTER=openai/gpt-4.1
# STRIX_LLM_VISION=openai/gpt-4.1-mini
# STRIX_LLM_MEMORY=openai/gpt-4.1-mini
# STRIX_LLM_DEDUPE=openai/gpt-4.1-mini

# --- Sandbox reachability from API (Live Browser / noVNC proxy) --------------
# Published sandbox ports live on the Docker host. The API container reaches
# them via STRIX_SANDBOX_HOST (docker-compose defaults to host.docker.internal).
# If Live Browser shows 502, try STRIX_SANDBOX_FALLBACK_HOSTS=172.17.0.1 or your
# host gateway IP (Linux varies).
# STRIX_SANDBOX_FALLBACK_HOSTS=

# --- Sandbox image ----------------------------------------------------------
# The container image NovaHunter spawns per scan (Kali + Burp CE + Caido +
# headless browser + noVNC + shellinabox + openvpn + capability installer).
# Custom NovaHunter sandbox (built by .github/workflows/sandbox-image.yml):
# STRIX_IMAGE=ghcr.io/maramharsha/novahunter-sandbox:latest
# Upstream Strix sandbox (or your mirror from mirror-strix-sandbox workflow):
# STRIX_IMAGE=ghcr.io/maramharsha/strix-sandbox-mirror:latest
